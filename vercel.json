{
  "crons": [
    {
      "path": "/api/cron/sync-eld",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/alert-escalations",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/morning-digest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/cleanup-api-cache",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-notifications",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/auto-maintenance",
      "schedule": "0 5 * * 0"
    }
  ],
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "buildCommand": "next build",
  "installCommand": "npm install",
  "framework": "nextjs"
}

