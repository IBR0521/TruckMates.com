{
  "crons": [
    {
      "path": "/api/cron/sync-eld",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/scan-hos-violations",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/scan-detention",
      "schedule": "7,22,37,52 * * * *"
    },
    {
      "path": "/api/cron/alert-escalations",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/morning-digest",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/generate-briefings",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/cleanup-api-cache",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/cleanup-notifications",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/auto-maintenance",
      "schedule": "0 5 * * 0"
    },
    {
      "path": "/api/cron/sync-diesel-price",
      "schedule": "0 6 * * 1"
    },
    {
      "path": "/api/cron/sync-csa-scores",
      "schedule": "0 7 1 * *"
    },
    {
      "path": "/api/cron/sync-fuel-card-transactions",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron/sync-factoring-status",
      "schedule": "*/35 * * * *"
    },
    {
      "path": "/api/cron/expire-trials",
      "schedule": "20 * * * *"
    },
    {
      "path": "/api/cron/process-smart-notifications",
      "schedule": "*/15 * * * *"
    }
  ],
  "functions": {
    "app/api/cron/generate-briefings/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/cron/process-smart-notifications/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "app/api/**/*.ts": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "buildCommand": "next build",
  "installCommand": "npm install",
  "framework": "nextjs"
}

