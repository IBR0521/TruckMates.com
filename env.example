# Supabase Configuration (REQUIRED)
# Get these values from your Supabase project dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service Role Key (only use in server-side code, never expose to client)
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Rate limiting (REQUIRED in production)
# Production startup fails unless both are set.
UPSTASH_REDIS_REST_URL=https://your-upstash-endpoint.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# App URL (for redirects and OAuth callbacks)
NEXT_PUBLIC_APP_URL=https://your-domain.com
# For local development: NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================
# API KEYS FOR FULL FEATURE FUNCTIONALITY
# ============================================

# Google Maps API (REQUIRED for Route Optimization)
# Get from: https://console.cloud.google.com/
# Steps:
# 1. Create project or select existing
# 2. Enable "Maps JavaScript API" and "Directions API"
# 3. Create API key
# 4. Restrict key to your domain (recommended)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Resend Email Service (REQUIRED for Email Notifications)
# Get from: https://resend.com/api-keys
# Steps:
# 1. Sign up at https://resend.com/
# 2. Verify your domain (or use Resend's domain)
# 3. Get API key from dashboard
RESEND_API_KEY=re_xxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Admin email for receiving feedback notifications
ADMIN_EMAIL=your-email@gmail.com

# Twilio SMS Service (OPTIONAL - for SMS Notifications)
# Get from: https://www.twilio.com/console
# Steps:
# 1. Sign up at https://www.twilio.com/
# 2. Get Account SID and Auth Token from dashboard
# 3. Get phone number (or use trial number)
# Twilio Account SID that identifies your Twilio project/account.
TWILIO_ACCOUNT_SID=your_twilio_account_sid
# Twilio Auth Token used by server-side API calls to send SMS securely.
TWILIO_AUTH_TOKEN=your_twilio_auth_token
# Twilio sender phone number in E.164 format (used as "from" number), e.g. +1234567890.
TWILIO_PHONE_NUMBER=+1234567890

# Stripe Payment Processing (OPTIONAL - for Invoice Payments)
# Get from: https://dashboard.stripe.com/apikeys
# Steps:
# 1. Sign up at https://stripe.com/
# 2. Get API keys from dashboard
# 3. Use test keys for development, live keys for production
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx
# Get webhook secret from: Stripe Dashboard → Webhooks

# PayPal Payment Processing (OPTIONAL - for Invoice Payments)
# Get from: https://developer.paypal.com/dashboard/applications
# Steps:
# 1. Sign up at https://developer.paypal.com/
# 2. Create app
# 3. Get Client ID and Secret
# 4. Use sandbox for testing, live for production
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_CLIENT_SECRET=your_paypal_client_secret
PAYPAL_MODE=sandbox
# For production: PAYPAL_MODE=live
PAYPAL_WEBHOOK_ID=your_webhook_id
# Get webhook ID from: PayPal Dashboard → Webhooks

# QuickBooks Integration (OPTIONAL - for Accounting Sync)
# Get from: https://developer.intuit.com/
# Steps:
# 1. Create app at https://developer.intuit.com/
# 2. Get OAuth 2.0 credentials (Client ID, Client Secret)
# 3. Set up OAuth flow
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_REDIRECT_URI=https://your-domain.com/api/quickbooks/callback

# Firebase Cloud Messaging (OPTIONAL - for mobile/web push notifications)
# Client SDK (safe to expose with NEXT_PUBLIC_)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_web_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef123456
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_web_push_certificate_key_pair
# Server/Admin SDK (server only)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Sentry Error Tracking (OPTIONAL but recommended)
# Get from: https://sentry.io/settings/projects/
NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
NEXT_PUBLIC_SENTRY_DEBUG=false

# Anthropic Claude API (OPTIONAL - for AI OCR and document analysis)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================
# ELD webhook HMAC secrets (OPTIONAL integrations)
# Self-generated shared secrets — not API keys from the vendor.
# Register the same value in each vendor’s webhook settings so outbound
# webhook requests are signed with HMAC-SHA256 using this secret.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SAMSARA_WEBHOOK_SECRET=
KEEPTRUCKIN_WEBHOOK_SECRET=
GEOTAB_WEBHOOK_SECRET=

