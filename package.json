{
  "name": "truckmates",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3000 --hostname 0.0.0.0 --webpack",
    "dev:platform": "bash scripts/dev-platform.sh",
    "dev:fresh": "rm -rf .next node_modules/.cache && NEXT_TELEMETRY_DISABLED=1 next dev -p 3000 --hostname 0.0.0.0 --webpack",
    "dev:fresh:turbo": "rm -rf .next node_modules/.cache && NEXT_TELEMETRY_DISABLED=1 next dev -p 3000 --hostname 0.0.0.0",
    "ports:free-3000": "lsof -ti :3000 | xargs kill -9 2>/dev/null || true",
    "deps:reinstall": "rm -rf node_modules .next && npm install",
    "dev:3003": "next dev -p 3003 --hostname :: --webpack",
    "dev:3003:turbo": "next dev -p 3003 --hostname ::",
    "dev:3010": "NEXT_TELEMETRY_DISABLED=1 next dev -p 3010 --hostname 0.0.0.0 --webpack",
    "dev:3004": "next dev -p 3004 --hostname 0.0.0.0",
    "dev:3004:webpack": "next dev -p 3004 --hostname 0.0.0.0 --webpack",
    "dev:webpack": "next dev -p 3000 --hostname 0.0.0.0 --webpack",
    "dev:turbo": "next dev -p 3000 --hostname 0.0.0.0",
    "dev:alt": "next dev -p 3001",
    "dev:open": "npm run dev:platform",
    "lint": "eslint .",
    "test": "vitest",
    "test:unit": "vitest --run",
    "test:ci": "vitest --run --reporter=dot",
    "start": "next start",
    "e2e:smoke": "node scripts/truckmates-smoke.mjs",
    "operations:hardtest": "node scripts/operations-hard-test.mjs",
    "eld:generate-test-csv": "node scripts/generate-eld-test-csv.mjs",
    "eld:generate-fmcsa-output": "node scripts/generate-fmcsa-eld-output.mjs",
    "verify:eld-telemetry-webhook": "node scripts/verify-eld-telemetry-webhook.mjs",
    "backfill:eld-credentials": "tsx scripts/backfill-eld-credential-encryption.ts",
    "ai:eval": "tsx scripts/ai-eval/run.mjs"
  },
