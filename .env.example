# Copy to `.env.local` and fill values (never commit `.env.local`).
# On Vercel: Settings → Environment Variables → paste the same names.

# --- Required for app auth / data (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional server-only (admin tasks, some scripts)
# SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (links, redirects, portal) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Google Maps (server + browser) ---
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Trip planning / ProMiles (server actions) ---
HERE_API_KEY=
EIA_API_KEY=

# --- QuickBooks (optional) ---
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI=
# QUICKBOOKS_SANDBOX=true

# --- Payments / email (optional) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# RESEND_API_KEY=
