# Copy to `.env.local` and fill values (never commit `.env.local`).
# On Vercel: Settings → Environment Variables → paste the same names.

# --- Required for app auth / data (Supabase) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Postgres pooler URI (postgresql://...) for optional direct PG access via lib/supabase/pooler-pg.ts.
# Never use as Supabase JS client URL — the JS SDK requires NEXT_PUBLIC_SUPABASE_URL (https).
SUPABASE_POOLER_URL=

# Optional server-only (admin tasks, some scripts)
# SUPABASE_SERVICE_ROLE_KEY=

# --- App URL (links, redirects, portal) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- SAML 2.0 SSO (Enterprise; server-only SP key pair) ---
# Generate with:
#   openssl req -x509 -newkey rsa:2048 -keyout saml-sp.key -out saml-sp.crt -days 3650 -nodes \
#     -subj "/CN=TruckMates SAML SP/O=TruckMates"
# SAML_SP_PRIVATE_KEY=
# SAML_SP_CERT=

# --- Google Maps (server + browser) ---
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- Trip planning / ProMiles (server actions) ---
HERE_API_KEY=
EIA_API_KEY=

# --- QuickBooks (optional) ---
# QUICKBOOKS_CLIENT_ID=
# QUICKBOOKS_CLIENT_SECRET=
# QUICKBOOKS_REDIRECT_URI=
# QUICKBOOKS_SANDBOX=true

# --- Playwright smoke (npm run e2e:smoke) ---
# If you see ERR_CONNECTION_REFUSED: start the app (`npm run dev`) and use localhost:
# PLAYWRIGHT_BASE_URL=http://localhost:3000
# PLAYWRIGHT_BASE_URL=https://truckmateslogistic.com
# PLAYWRIGHT_AUTH=login
# PLAYWRIGHT_EMAIL=
# PLAYWRIGHT_PASSWORD=
# Or: PLAYWRIGHT_AUTH=demo  (uses /demo/setup; slower, no credentials in script)
# After npm install: npx playwright install chromium

# --- Rate limiting (REQUIRED in production) ---
# Production startup fails unless both are set.
# Upstash Redis free tier: create a database and paste REST URL + token here and in Vercel.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Payments / email (optional) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Paddle Billing (active; Stripe reserved for future US LLC) ---
# Get from: paddle.com → Developer Tools → Authentication
# PADDLE_API_KEY=
# PADDLE_WEBHOOK_SECRET=
# PADDLE_VENDOR_ID=
# PADDLE_ENVIRONMENT=sandbox
# Client-side Paddle.js (must match PADDLE_ENVIRONMENT in production)
# NEXT_PUBLIC_PADDLE_ENVIRONMENT=production
# NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
# Per-tier catalog price IDs (Paddle Dashboard → Catalog → Prices), e.g.:
# PADDLE_PRICE_OWNER_OPERATOR_MONTHLY=
# PADDLE_PRICE_OWNER_OPERATOR_ANNUAL=
# PADDLE_PRICE_STARTER_MONTHLY=
# PADDLE_PRICE_STARTER_ANNUAL=
# PADDLE_PRICE_PROFESSIONAL_MONTHLY=
# PADDLE_PRICE_PROFESSIONAL_ANNUAL=
# PADDLE_PRICE_FLEET_MONTHLY=
# PADDLE_PRICE_FLEET_ANNUAL=
# BILLING_PROVIDER=paddle
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=
# RESEND_API_KEY=

# --- Internal Supabase DB webhook (eld_telemetry_points → geofence processing) ---
# Must match platform_http_targets.secret for target_key 'eld_telemetry_geofence' (migration 249).
# ELD_TELEMETRY_WEBHOOK_SECRET=
# After migration 249: npm run verify:eld-telemetry-webhook -- --configure
# Live ping: npm run verify:eld-telemetry-webhook -- --ping --company-id <uuid>

# --- ELD provider credential encryption (server-only) ---
# Generate with: openssl rand -base64 32
# ELD_CREDENTIALS_ENCRYPTION_KEY=
